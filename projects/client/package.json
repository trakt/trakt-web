{
  "name": "client",
  "version": "0.0.1",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "pre:dev": "deno task i18n:web:watch",
    "dev": "concurrently 'deno task pre:dev' 'vite dev'",
    "dev:staging": "concurrently 'deno task pre:dev' 'cross-env IS_STAGING=true vite dev'",
    "dev:contrib": "concurrently 'deno task pre:dev' 'cross-env  IS_CONTRIB=true vite dev'",
    "dev:local": "concurrently 'deno task pre:dev' 'cross-env IS_LOCAL=true vite dev'",
    "prebuild": "deno task i18n:web",
    "build": "vite build",
    "prebuild:preview": "deno task prebuild",
    "build:preview": "IS_PREVIEW=true vite build",
    "build:doctor": "IS_DOCTOR=true vite build --mode doctor",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "pretest:unit": "deno task prebuild",
    "test:unit": "vitest",
    "test:doctor": "vitest --run --reporter=dot",
    "pretest:cov": "deno task prebuild",
    "test:cov": "vitest --coverage",
    "test:e2e": "cucumber-js -c ./cucumber.mjs",
    "i18n:web": "deno task i18n:generate ./i18n --platforms web",
    "i18n:web:watch": "deno task i18n:generate:watch ./i18n --platforms web",
    "i18n:compile": "deno run -A npm:@inlang/paraglide-js compile --project ./i18n/project.inlang --outdir ./src/lib/paraglide",
    "i18n:prepare": "deno task i18n:web && deno task i18n:compile",
    "sync:immutable": "deno run --allow-net --allow-read --allow-env .scripts/sync-immutable-to-r2.ts",
    "prune:immutable": "deno run --allow-net --allow-env .scripts/prune-immutable-r2.ts",
    "i18n:resolve": "deno run --allow-read --allow-write .scripts/resolve-i18n.ts",
    "i18n:check": "deno run --allow-read .scripts/check-i18n-placeholders.ts",
    "i18n:generate": "deno run --allow-read --allow-write i18n/generator/cli.ts -i i18n/meta/ -o i18n/",
    "i18n:generate:watch": "deno run --allow-read --allow-write i18n/generator/cli.ts -i i18n/meta/ -o i18n/ --watch"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260702.1",
    "@cucumber/cucumber": "13.0.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/adapter-cloudflare": "7.2.9",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.4.2",
    "@testing-library/user-event": "14.6.1",
    "@types/d3": "7.4.3",
    "@types/eslint": "9.6.1",
    "@types/serviceworker": "0.0.199",
    "@vite-pwa/sveltekit": "1.1.0",
    "@vitest/coverage-istanbul": "4.1.9",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "@types/papaparse": "5.5.2",
    "esbuild": "0.28.1",
    "eslint": "10.6.0",
    "eslint-plugin-svelte": "3.20.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "msw": "2.14.6",
    "playwright": "1.61.1",
    "prettier": "3.9.4",
    "prettier-plugin-svelte": "4.1.1",
    "sass-embedded": "1.100.0",
    "svelte-check": "4.7.1",
    "typescript": "5.8.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@ethercorps/sveltekit-og": "4.2.1",
    "@inlang/paraglide-js": "2.20.2",
    "@libn/fuzzy": "npm:@jsr/libn__fuzzy@0.4.0",
    "@sentry/sveltekit": "10.63.0",
    "@sveltejs/kit": "2.69.1",
    "@svelte-put/shortcut": "4.2.0",
    "@tanstack/query-core": "5.101.2",
    "@tanstack/query-devtools": "5.101.2",
    "@tanstack/query-persist-client-core": "5.101.2",
    "@trakt/api": "npm:@jsr/trakt__api@0.4.20",
    "@ts-rest/core": "3.52.1",
    "@use-gesture/vanilla": "10.3.1",
    "bits-ui": "2.18.1",
    "date-fns": "4.4.0",
    "fflate": "0.8.3",
    "firebase": "12.15.0",
    "idb-keyval": "6.2.6",
    "marked": "18.0.5",
    "oidc-client-ts": "3.5.0",
    "plyr": "3.8.4",
    "resolve-accept-language": "3.2.2",
    "rxjs": "7.8.2",
    "svelte": "5.56.4",
    "svelte-confetti": "2.3.2",
    "ts-retry": "7.0.3",
    "typesense": "3.0.6",
    "workbox-expiration": "7.4.1",
    "workbox-precaching": "7.4.1",
    "workbox-routing": "7.4.1",
    "workbox-strategies": "7.4.1",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.25.2",
    "papaparse": "5.5.4",
    "@carbon/charts": "1.27.16",
    "@carbon/charts-svelte": "1.27.16",
    "d3": "7.9.0"
  }
}
